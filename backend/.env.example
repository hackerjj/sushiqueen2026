APP_NAME="MealLi POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# MongoDB
DB_CONNECTION=mongodb
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DATABASE=sushi_queen
MONGO_USERNAME=sushiqueen
MONGO_PASSWORD=sushiqueen_secret
MONGO_AUTH_SOURCE=admin

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=sushiqueen_redis
REDIS_PORT=6379

# Cache (use "redis" in production for rate limiting and caching)
CACHE_DRIVER=redis

# JWT
JWT_SECRET=
JWT_TTL=60

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Prometheus Metrics
METRICS_TOKEN=

# Google AI Studio (Gemini)
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash
